<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jake Sirota</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      font-size: 20px;
      scroll-behavior: smooth;
    }

    body {
      background: #ffffff;
      color: #111111;
      font-family: 'EB Garamond', Georgia, serif;
      line-height: 1.75;
    }

    .site {
      max-width: 860px;
      margin: 0 auto;
      padding: 4rem 2.5rem 6rem;
    }

    /* ── Giant name header ── */
    h1 {
      font-family: Arial, 'Helvetica Neue', sans-serif;
      font-weight: 900;
      font-size: clamp(3.2rem, 10vw, 5.8rem);
      line-height: 1.0;
      letter-spacing: -0.02em;
      color: #111111;
      margin-bottom: 3rem;
    }

    /* ── Nav ── */
    nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.2rem 0;
      margin-bottom: 3rem;
      border-top: 1.5px solid #111;
      border-bottom: 1.5px solid #111;
      padding: 0.5rem 0;
    }

    nav a {
      font-family: Arial, 'Helvetica Neue', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #111;
      text-decoration: none;
      margin-right: 2rem;
    }

    nav a:hover { opacity: 0.5; }

    /* ── Body prose ── */
    p {
      font-size: 1rem;
      margin-bottom: 1.3em;
      text-align: justify;
      hyphens: auto;
    }

    p:last-child { margin-bottom: 0; }

    a {
      color: #111;
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
    }

    a:hover { opacity: 0.6; }

    /* ── Keyword highlights ── */
    /* Each k-* class is a distinct highlight color, pill-shaped */
    .k {
      display: inline;
      padding: 0.05em 0.35em 0.08em;
      border-radius: 3px;
      font-style: normal;
      white-space: nowrap;
    }

    /* A palette of 10 distinct highlight colors, muted/earthy like Bolman */
    .k1  { background: #4a7c6f; color: #fff; }  /* teal-green */
    .k2  { background: #c85a2a; color: #fff; }  /* burnt orange */
    .k3  { background: #7b5ea7; color: #fff; }  /* purple */
    .k4  { background: #3d7abf; color: #fff; }  /* blue */
    .k5  { background: #b84a6a; color: #fff; }  /* rose */
    .k6  { background: #5a8a3c; color: #fff; }  /* olive green */
    .k7  { background: #c9933a; color: #fff; }  /* amber */
    .k8  { background: #4a7ab8; color: #fff; }  /* slate blue */
    .k9  { background: #8a4a4a; color: #fff; }  /* brick */
    .k10 { background: #4a6e8a; color: #fff; }  /* steel blue */

    /* ── Section headers ── */
    .section-head {
      font-family: Arial, 'Helvetica Neue', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #111;
      margin-top: 3.5rem;
      margin-bottom: 1.2rem;
      padding-top: 2rem;
      border-top: 1.5px solid #111;
    }

    /* ── CV ── */
    .cv-group { margin-bottom: 2rem; }

    .cv-group-label {
      font-family: Arial, 'Helvetica Neue', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #777;
      margin-bottom: 0.6rem;
    }

    .cv-row {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 0 1.2rem;
      margin-bottom: 0.5rem;
      font-size: 0.92rem;
      line-height: 1.55;
    }

    .cv-year {
      color: #999;
      font-size: 0.82rem;
      padding-top: 0.05em;
      font-variant-numeric: tabular-nums;
    }

    .cv-note {
      font-size: 0.82rem;
      color: #777;
      margin-top: 0.15rem;
    }

    /* ── Teaching ── */
    .course {
      margin-bottom: 1rem;
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .course-name { font-style: italic; }
    .course-role { font-size: 0.8rem; color: #888; }

    /* ── Footer ── */
    .footer {
      margin-top: 4rem;
      padding-top: 1rem;
      border-top: 1.5px solid #111;
      font-family: Arial, 'Helvetica Neue', sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #999;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .footer a {
      color: #999;
      text-decoration: none;
    }

    .footer a:hover { color: #111; }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      html { font-size: 17px; }
      .site { padding: 2.5rem 1.2rem 4rem; }
      p { text-align: left; hyphens: none; }
      .cv-row { grid-template-columns: 64px 1fr; }
    }
  </style>
</head>
<body>
